{
  "info": {
    "_postman_id": "7523a488-ad46-45ec-b0a3-d5127e183aa4",
    "name": "ServiceNow Import Set API",
    "description": "The ServiceNow Import Set API allows external systems to push data into ServiceNow import set staging tables, which can then be synchronously or asynchronously transformed and loaded into target tables using transform maps. It is commonly used for integrating external data sources with ServiceNow for bulk data loading and ETL workflows.\n\nContact Support:\n Name: ServiceNow Support",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
