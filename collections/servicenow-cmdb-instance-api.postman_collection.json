          "name": "Servicenow List Configuration Items by Class",
          "request": {
            "name": "Servicenow List Configuration Items by Class",
            "description": {
              "content": "Retrieves a list of configuration item instances for the specified CMDB class. Returns sys_id and name for each CI by default.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "instance",
                ":className"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "sysparm_query",
                  "value": "<string>",
                  "description": "An encoded query string to filter CI records."
                },
                {
                  "disabled": false,
                  "key": "sysparm_limit",
                  "value": "1000",
                  "description": "Maximum number of records to return. Default is 1000."
                },
                {
                  "disabled": false,
                  "key": "sysparm_offset",
                  "value": "0",
                  "description": "Starting record index for pagination."
                }
              ],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "className",
                  "description": "(Required) The CMDB class name to query, such as cmdb_ci_server, cmdb_ci_linux_server, cmdb_ci_appl, or cmdb_ci_apache_web_server."
                },
                {
                  "description": "Your ServiceNow instance name",
                  "type": "any",
                  "value": "{{instance}}",
                  "key": "instance"
                }
              ]
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
