  "info": {
    "_postman_id": "0a21036b-6827-4406-8d16-5d53e1f92a45",
    "name": "ServiceNow Import Set API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The ServiceNow Import Set API allows external systems to push data into ServiceNow import set staging tables, which can then be synchronously or asynchronously transformed and loaded into target tables using transform maps. It is commonly used for integrating external data sources with ServiceNow for bulk data loading and ETL workflows.\n\nContact Support:\n Name: ServiceNow Support",
      "type": "text/plain"
    }
  }
