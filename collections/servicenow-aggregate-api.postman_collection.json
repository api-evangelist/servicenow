  "info": {
    "_postman_id": "67af0bec-8bda-4d7a-acfc-66e27f09dc5f",
    "name": "ServiceNow Aggregate API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The ServiceNow Aggregate API provides endpoints to compute aggregate statistics against records in any ServiceNow table. It supports count, average, minimum, maximum, and sum operations with optional grouping and filtering, making it useful for reporting dashboards and analytics integrations.\n\nContact Support:\n Name: ServiceNow Support",
